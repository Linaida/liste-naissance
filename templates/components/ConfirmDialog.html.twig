<div {{ attributes }}
     id="{{ id }}"
     data-controller="dialog"
     data-dialog-target="modal"
     class="hidden fixed inset-0 z-50 items-center justify-center">

	{# Overlay #}
	<div class="absolute inset-0 bg-black/40 backdrop-blur-sm"
	     data-action="click->dialog#close"></div>

	{# Modal #}
	<div class="relative bg-white rounded-3xl shadow-2xl w-full max-w-md p-8">

		<h3 class="text-lg font-semibold text-gray-800 mb-4">
			<span data-dialog-target="title"></span>
		</h3>

		<p data-dialog-target="message" class="mb-6 text-gray-600"></p>
        <p>
            <strong data-dialog-target="name"></strong>
        </p>

		<div class="flex justify-end gap-3">
			<button type="button"
			        data-action="dialog#close"
			        class="px-4 py-2 text-sm font-medium rounded-full bg-gray-100 hover:bg-gray-200">
				Annuler
			</button>

			<form method="post" data-dialog-target="form">
				<input type="hidden" name="_token" data-dialog-target="csrf">

				<button type="submit"
				        class="px-4 py-2 text-sm font-medium text-white rounded-full
				               bg-linear-to-r from-red-500 to-red-700 hover:scale-105 transition">
					Supprimer
				</button>
			</form>
		</div>
	</div>
</div>
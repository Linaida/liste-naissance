<div class="
    bg-pink-50/80 backdrop-blur-md
    rounded-3xl shadow-lg
    border border-pink-100/40
    overflow-hidden
    hover:shadow-xl hover:-translate-y-1
    transition-all duration-300
">

    {# IMAGE #}
    <div class="aspect-square bg-gray-100 overflow-hidden article-image">
        {% if article.imagePath %}
            {% set imageSrc =
                article.imagePath starts with 'http'
                    ? article.imagePath
                    : asset('uploads/articles/' ~ article.imagePath)
            %}
            <img src="{{ imageSrc }}"
                 class="w-full object-cover">
        {% else %}
            <div class="w-full h-full flex items-center justify-center text-gray-400 text-sm">
                Aucune image
            </div>
        {% endif %}
    </div>

    {# CONTENT #}
    <div class="p-4 space-y-2">
        <h3 class="font-semibold text-gray-800">
            {{ article.name }}
        </h3>

        <div class="flex items-center justify-between">

            <span class="text-sm font-medium text-indigo-600">
                {{ article.price ? article.price ~ ' €' : '—' }}
            </span>

            {% if article.booked %}
                <span class="px-2 py-1 text-xs font-semibold
                             bg-pink-100 text-pink-700
                             rounded-full">
                    Réservé
                </span>
            {% else %}
                <span class="px-2 py-1 text-xs font-semibold
                             bg-emerald-100 text-emerald-700
                             rounded-full">
                    Disponible
                </span>
            {% endif %}
        </div>
         
    </div>
    {# Liens vers les plateformes de vente en ligne #}    
    <div>
    {% if article.links is not empty %}
        <div class="px-4 pb-4">
            <h4 class="text-sm font-medium text-gray-600 mb-2">
                Où acheter ? 🛒
            </h4>
            <div class="flex flex-wrap gap-2">
                {% for link in article.links %}
                    <a href="{{ link.url }}" target="_blank" class="inline-block px-3 py-1 text-sm 
                            text-indigo-600 border 
                            hover:bg-indigo-400 hover:text-white transition-colors duration-300">
                        {{ link.label }}
                    </a>
                {% endfor %}
            </div>
        </div>
    {% endif %}
    </div>
    <div>
    {% if not article.booked %}
         <div class="flex justify-center">
             <button
                type="button"
                data-action="reservation#openModal"
                data-article-id="{{ article.id }}"
                data-article-name="{{ article.name }}"
                class="inline-block mt-2 px-4 py-1 text-sm 
                        text-pink-600 border border-pink-600 rounded-lg
                       hover:bg-pink-400 hover:text-white cursor-pointer transition-colors duration-300">
                 Réserver
             </button>
             </div>
             {% else %}
                <div class="flex justify-center">
                    <button
                        type="button"
                        data-action="reservation#openCancelModal"
                        data-article-id="{{ article.id }}"
                        data-article-name="{{ article.name }}"
                        class="inline-block mt-2 px-4 py-1 text-sm 
                                text-orange-400 border border-orange-400 rounded-lg
                                cursor-pointer">
                        Annuler la réservation
                    </button>
                </div>
        {% endif %}
    </div>

</div>
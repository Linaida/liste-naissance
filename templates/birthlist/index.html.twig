{% extends 'base.html.twig' %}

{% block title %}Liste de naissance
{% endblock %}

{% block body %}
	{# Toast Container #}
	<div id="toast-container" class="fixed top-4 right-4 z-[9999] flex flex-col"></div>

	<div data-controller="reservation articles-list">
		<turbo-frame id="articles-list" data-articles-list-target="frame">
			<div class="mx-2 my-2">
				{% include 'birthlist/partials/_filters.html.twig' with {
	      		categories: categories
	    	} %}
			</div>
			<div class="mx-2">

				{% include 'birthlist/partials/_articles.html.twig' with {
					articles: articles,
					categories: categories
				} %}

			</div>
		</turbo-frame>

		{# RESERVATION MODAL #}
		<div 
			data-reservation-target="modal"
			data-action="click->reservation#handleBackdropClick"
			class="hidden fixed inset-0 bg-grey bg-opacity-10 flex items-center justify-center z-50 backdrop-blur-md"
		>
			<div class="
				bg-white
				rounded-3xl
				shadow-2xl
				p-8
				max-w-md w-full mx-4
				border border-pink-100
			">
				<h2 
					data-reservation-title
					class="text-2xl font-bold text-indigo-800 mb-6">
					Réserver un article
				</h2>

				<form data-reservation-target="form" data-action="submit->reservation#submitReservation" class="space-y-5">
					
					{# NOM #}
					<div class="flex flex-col">
						<label for="reservation-name" class="
							text-sm font-medium
							text-indigo-600
							mb-2
						">
							Votre nom *
						</label>
						<input 
							type="text"
							id="reservation-name"
							data-reservation-target="nameInput"
							placeholder="Jean Dupont"
							required
							class="
								w-full px-4 py-3
								rounded-2xl
								border border-indigo-200
								bg-white
								text-indigo-800
								shadow-sm
								placeholder-indigo-300
								focus:outline-none
								focus:ring-2 focus:ring-indigo-300
								focus:border-indigo-300
								transition-all duration-200
							"
						>
					</div>

					{# EMAIL #}
					<div class="flex flex-col">
						<label for="reservation-email" class="
							text-sm font-medium
							text-indigo-600
							mb-2
						">
							Email *
						</label>
						<input 
							type="email"
							id="reservation-email"
							data-reservation-target="emailInput"
							placeholder="votre@email.com"
							required
							class="
								w-full px-4 py-3
								rounded-2xl
								border border-indigo-200
								bg-white
								text-indigo-800
								shadow-sm
								placeholder-indigo-300
								focus:outline-none
								focus:ring-2 focus:ring-indigo-300
								focus:border-indigo-300
								transition-all duration-200
							"
						>
					</div>

					{# MESSAGE OPTIONNEL #}
					<div class="flex flex-col">
						<label for="reservation-message" class="
							text-sm font-medium
							text-indigo-600
							mb-2
						">
							Message (optionnel)
						</label>
						<textarea 
							id="reservation-message"
							data-reservation-target="messageInput"
							placeholder="Ajoutez un message..."
							rows="4"
							class="
								w-full px-4 py-3
								rounded-2xl
								border border-indigo-200
								bg-white
								text-indigo-800
								shadow-sm
								placeholder-indigo-300
								focus:outline-none
								focus:ring-2 focus:ring-indigo-300
								focus:border-indigo-300
								transition-all duration-200
								resize-none
							"
						></textarea>
					</div>

					{# BUTTONS #}
					<div class="flex gap-3 pt-4">
						<button 
							type="button"
							data-action="reservation#closeModal"
							class="
								flex-1 px-4 py-2
								text-indigo-600 font-semibold
								border border-indigo-300
								rounded-2xl
								hover:bg-indigo-50
								transition-colors duration-200
							"
						>
							Annuler
						</button>
						<button 
							type="submit"
							class="
								flex-1 px-4 py-2
								text-white font-semibold
								rounded-2xl
								bg-gradient-to-r from-blue-400 to-indigo-400
								hover:shadow-lg
								transition-all duration-200
							"
						>
							Valider
						</button>
					</div>
				</form>
			</div>
		</div>

		{# CANCEL RESERVATION MODAL #}
		<div 
			data-reservation-target="cancelModal"
			data-action="click->reservation#handleCancelBackdropClick"
			class="hidden fixed inset-0 bg-grey bg-opacity-10 flex items-center justify-center z-50 backdrop-blur-md"
		>
			<div class="
				bg-white
				rounded-3xl
				shadow-2xl
				p-8
				max-w-md w-full mx-4
				border border-orange-100
			">
				<h2 
					data-reservation-cancel-title
					class="text-2xl font-bold text-orange-800 mb-6">
					Annuler la réservation
				</h2>

				<form data-reservation-target="cancelForm" data-action="submit->reservation#submitCancelReservation" class="space-y-5">
					
					{# EMAIL #}
					<div class="flex flex-col">
						<label for="cancel-email" class="
							text-sm font-medium
							text-orange-600
							mb-2
						">
							Email de réservation *
						</label>
						<input 
							type="email"
							id="cancel-email"
							data-reservation-target="cancelEmailInput"
							placeholder="votre@email.com"
							required
							class="
								w-full px-4 py-3
								rounded-2xl
								border border-orange-200
								bg-white
								text-orange-800
								shadow-sm
								placeholder-orange-300
								focus:outline-none
								focus:ring-2 focus:ring-orange-300
								focus:border-orange-300
								transition-all duration-200
							"
						>
					</div>

					{# BUTTONS #}
					<div class="flex gap-3 pt-4">
						<button 
							type="button"
							data-action="reservation#closeCancelModal"
							class="
								flex-1 px-4 py-2
								text-orange-600 font-semibold
								border border-orange-300
								rounded-2xl
								hover:bg-orange-50
								transition-colors duration-200
							"
						>
							Annuler
						</button>
						<button 
							type="submit"
							class="
								flex-1 px-4 py-2
								text-white font-semibold
								rounded-2xl
								bg-gradient-to-r from-orange-400 to-orange-500
								hover:shadow-lg
								transition-all duration-200
							"
						>
							Confirmer
						</button>
					</div>
				</form>
			</div>
		</div>

</div>
{% endblock %}
<div class="flex flex-col flex-wrap gap-3 mb-8">
	<div class="flex items-center gap-2">
		<a href="{{ path('birthlist') }}" data-turbo-frame="articles" class="filter-chip
				{% if app.request.query.get('category') is null %} filter-chip-active {% else %}  filter-chip-inactive
				{% endif %}"> 
			Tous
		</a>

		{% for cat in categories %}

			<a href=" {{ path('birthlist', app.request.query.all|merge({category: cat.value} )) }}" data-turbo-frame=" articles" class="filter-chip
								{% if app.request.query.get('category') === cat.value  %}
									filter-chip-active {% else %}  filter-chip-inactive
									{% endif %} ">

				{{ cat.label() }}

			</a>

		{% endfor %}
	</div>
	<div class="flex items-center gap-2">
		<a href="{{ path('birthlist', app.request.query.all|merge({status: ''})) }}" data-turbo-frame="articles" class="filter-chip
										{% if app.request.query.get('status') == '' %}
										filter-chip-active {% else %}  filter-chip-inactive
										{% endif %}
										">
			Tous
		</a>
        <a href="{{ path('birthlist', app.request.query.all|merge({status: 'available'})) }}" data-turbo-frame="articles" class="filter-chip
										{% if app.request.query.get('status') == 'available' %}
										filter-chip-active {% else %}  filter-chip-inactive
										{% endif %}
										">
			Disponibles
		</a>
		<a href="{{ path('birthlist', app.request.query.all|merge({status: 'booked'})) }}" data-turbo-frame="articles" class="filter-chip
							{% if app.request.query.get('status') == 'booked' %}
							filter-chip-active {% else %}  filter-chip-inactive
							{% endif %}
							">
			Réservés
		</a>

	</div>
	<div class="flex items-center gap-2">
		<a href="{{ path('birthlist', app.request.query.all|merge({sort: 'price_asc'})) }}" data-turbo-frame="articles" class="filter-chip
				{% if app.request.query.get('sort') is null or app.request.query.get('sort') == 'price_asc'  %}
				filter-chip-active {% else %}  filter-chip-inactive
				{% endif %}
				">
			Prix ↑
		</a>
        <a href="{{ path('birthlist', app.request.query.all|merge({sort: 'price_desc'})) }}" data-turbo-frame="articles" class="filter-chip
				{% if app.request.query.get('sort') == 'price_desc' %}
				filter-chip-active {% else %}  filter-chip-inactive
				{% endif %}
				">
			Prix ↓
		</a>
	</div>
</div>

{% extends 'base.html.twig' %}

{% block title %}Administration | Articles
{% endblock %}

{% block body %}

	<div class="container mx-auto px-4 py-12">
		<div class="flex flex-col">
			<div class="relative p-8 flex flex-col w-full h-full text-gray-700 bg-pink-50 shadow-xl rounded-3xl border border-pink-100 ">
				<div class="flex flex-col items-start gap-8 mb-8">
					<div
						class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6 mb-8 w-full">

						<!-- Bloc gauche : bouton pour retour à l'accueil -->
						<twig:BackLink href="{{ path('app_home') }}" label="Retour à l'accueil"/>

						<!-- Bloc central : titre et description -->
						<div class="flex flex-col  gap-1 text-left">

							<h5 class="text-2xl font-semibold text-gray-800">
								Mes articles de naissance
							</h5>
							<p class="text-sm text-gray-600">
								Liste de tous les articles disponibles dans le système.
							</p>
						</div>

						<!-- Bloc droite : actions -->
						<div class="flex  gap-3">
							<button class="px-4 py-2 text-xs font-semibold rounded-full bg-blue-100 text-blue-700 hover:bg-blue-200 transition">
								Filtrer
							</button>

							<a href="{{ path('articles_new') }}" class="px-5 py-2 text-xs font-semibold text-white rounded-full bg-linear-to-r from-blue-400 to-indigo-400 shadow-md hover:scale-105 transition-transform duration-150" data-turbo-frame="article_form">
								Ajouter un article
							</a>
						</div>

					</div>
					<div class="w-full overflow-x-auto">
						<turbo-frame id="articles_list">
							{% include 'article/_list.html.twig' %}
						</turbo-frame>
					</div>
				</div>
			</div>
		</div>
	{% endblock %}

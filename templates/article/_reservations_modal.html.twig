<div>
	<h2 class="text-2xl font-bold text-center text-indigo-800 mb-6">
		📋 Réservations - {{ article.name }}
	</h2>

	{% if reservations is not empty %}
		<div class="space-y-4 max-h-96 overflow-y-auto">
			{% for reservation in reservations %}
				<div class="p-4 bg-blue-50 border border-blue-200 rounded-lg">
					<div class="space-y-3">
						<div>
							<h4 class="text-sm font-medium text-blue-700">Nom</h4>
							<p class="text-blue-900 font-semibold">{{ reservation.name }}</p>
						</div>

						<div>
							<h4 class="text-sm font-medium text-blue-700">Email</h4>
							<p class="text-blue-900">
								<a href="mailto:{{ reservation.email }}" class="hover:underline text-indigo-600">
									{{ reservation.email }}
								</a>
							</p>
						</div>

						{% if reservation.message %}
							<div>
								<h4 class="text-sm font-medium text-blue-700">Message</h4>
								<p class="text-blue-900 text-sm italic">{{ reservation.message }}</p>
							</div>
						{% endif %}

						<div class="pt-2 border-t border-blue-200 text-xs text-blue-600">
							Réservé le {{ reservation.createdAt ? reservation.createdAt|date('d/m/Y à H:i') : 'N/A' }}
						</div>
					</div>
				</div>
			{% endfor %}
		</div>
	{% else %}
		<div class="text-center py-8">
			<p class="text-gray-600 text-lg">Aucune réservation pour cet article</p>
		</div>
	{% endif %}
</div>

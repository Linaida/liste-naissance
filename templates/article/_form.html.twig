<div data-controller="articles" class="form-article mx-auto mt-2">
	<div class="
			p-6
			flex flex-col
			text-indigo-700
			bg-pink-50/95
			backdrop-blur-md
			shadow-[0_30px_60px_rgba(0,0,0,0.12)]
			rounded-3xl
			border border-white/40
		">

		<h2 class="text-2xl font-semibold text-center text-indigo-800 mb-4">
			{{ article is defined ? 'Modifier l’article ✏️' : 'Ajouter un article 💕' }}
		</h2>

		<div
			class="flex flex-col space-y-6">

			{# ===== NAME ===== #}
			<div class="flex flex-col">
				<div class="flex items-center justify-between gap-4">
					<div class="flex-1">
						{{ form_label(form.name, null, {
                            label_attr: { class: 'text-sm font-medium text-indigo-600 mb-2' }
                        }) }}

						{{ form_widget(form.name, {
                            attr: {
                                class: '
                                    w-full px-2 py-2
                                    rounded-2xl
                                    border border-white/50
                                    bg-white/70
                                    backdrop-blur-sm
                                    text-indigo-800
                                    shadow-inner
                                    focus:outline-none
                                    focus:ring-2 focus:ring-indigo-300
                                    focus:border-indigo-300
                                    transition-all duration-200
                                ',
                                'data-articles-target' : 'articleName'
                            }
                        }) }}

						{{ form_errors(form.name) }}
					</div>
					<button 
						type="button"e
						data-action="articles#generateSearchLinks"
						class="mt-7 px-4 py-2
							text-sm font-medium text-white
							rounded-2xl
							bg-linear-to-r from-purple-400 to-pink-400
							shadow-md
							hover:shadow-lg
							hover:scale-105
							active:scale-95
							transition-all duration-200
							whitespace-nowrap
						">
						🔗 Générer les liens
					</button>
				</div>
			</div>
			{# ===== PRIX ===== #}
			<div>
				{{ form_label(form.price, null, {
                    label_attr: { class: 'text-sm font-medium text-indigo-600 mb-2' }
                }) }}

				{{ form_widget(form.price, {
                    attr: {
                        class: '
                            w-full px-2 py-2
                            rounded-2xl
                            border border-white/50
                            bg-white/70
                            backdrop-blur-sm
                            text-indigo-800
                            shadow-inner
                            focus:outline-none
                            focus:ring-2 focus:ring-indigo-300
                            focus:border-indigo-300
                            transition-all duration-200
                        '
                    }
                }) }}

				{{ form_errors(form.price) }}
			</div>
			{# ===== CATEGORY ===== #}
			<div>
				{{ form_label(form.category, null, {
					label_attr: { class: 'text-sm font-medium text-indigo-600 mb-2' }
				}) }}

				{{ form_widget(form.category, {
					attr: {
						class: '
							w-full px-2 py-2
							rounded-2xl
							border border-white/50
							bg-white/70
							backdrop-blur-sm
							shadow-inner
						'
					}
				}) }}

				{{ form_errors(form.category) }}
			</div>

			{# ===== IMAGE ===== #}
			<div
				data-controller="image-editor">

				{# --- IMAGE EXISTANTE --- #}
				{% if article is defined and article.imagePath %}
					{% set imageSrc = article.imagePath starts with 'http://' or article.imagePath starts with 'https://'
            ? article.imagePath
            : asset('uploads/articles/' ~ article.imagePath)
        %}

					<div class="relative inline-block">
						<img
						src="{{ imageSrc }}" class="w-40 h-40 object-cover rounded-2xl shadow-md border border-gray-200"/>

						{# Bouton crayon #}
						<button type="button" data-action="image-editor#toggle" class="absolute -bottom-2 -right-2
							w-9 h-9 rounded-full
							bg-white shadow-md border border-gray-200
							flex items-center justify-center
							hover:scale-105 transition">
							✏️
						</button>
					</div>
				{% endif %}

				{# --- ÉDITEUR IMAGE --- #}
				<div data-image-editor-target="panel" class="{% if article is defined and article.imagePath %}hidden{% endif %} mt-4">
					<twig:ImageChoice :imagefile="form.imageFile" :imageurl="form.imageUrl" label="Image de l’article"/>
				</div>

			</div>

			{# ===== LINKS ===== #}
			<div data-controller="store-detector">
				<h3 class="text-sm font-medium text-indigo-600 mb-4">
					Liens vers les boutiques 🔗
				</h3>

				<div data-articles-target="links" data-prototype="{{ form_widget(form.links.vars.prototype)|e('html_attr') }}" class="space-y-6">

				</div>
				<button type="button" id="add-link" data-action="articles#addLink" class="mt-4 text-sm font-medium text-indigo-600 hover:text-indigo-800">
					+ Ajouter un lien
				</button>
			</div>
			<div>
				{{ form_row(form._token) }}
			</div>
			{# ===== IS BOOKED ===== #}
		<div class="flex items-center">
    <span class="text-sm font-medium text-indigo-600">
        Article déjà réservé
    </span>

    <label class="relative inline-flex ml-6 items-center cursor-pointer">

        <input
            type="checkbox"
            name="{{ form.booked.vars.full_name }}"
            id="{{ form.booked.vars.id }}"
            value="1"
            {% if form.booked.vars.checked %}checked{% endif %}
            class="sr-only peer"
        >

        {# Track #}
        <div class="
            w-14 h-7
            bg-gray-300 rounded-full
            transition-colors
            peer-checked:bg-pink-400
            peer-focus:ring-4 peer-focus:ring-pink-200
        "></div>

        {# Knob #}
        <div class="
            absolute left-1 top-1
            w-5 h-5
            bg-white rounded-full shadow
            transition-transform
            peer-checked:translate-x-7
        "></div>

        {# NON #}
        <span class="
            absolute left-2 top-1/2 -translate-y-1/2
            text-[10px] font-bold
            text-indigo-600
            peer-checked:opacity-0
            transition
        ">
            NON
        </span>

        {# OUI #}
        <span class="
            absolute right-2 top-1/2 -translate-y-1/2
            text-[10px] font-bold
            text-indigo-600
            opacity-0
            peer-checked:opacity-100
            transition
        ">
            OUI
        </span>

    </label>
</div>
			{# ===== SUBMIT ===== #}
			<button type="submit" class="
				mx-auto w-70 py-2
				text-white font-semibold
				rounded-2xl
				bg-linear-to-r from-blue-400 to-indigo-400
				shadow-lg
				hover:shadow-xl
				hover:scale-[1.02]
				active:scale-95
				transition-all duration-200
			">
	Valider
			</button>
			<twig:BackLink href="{{ path('articles_list') }}" label="Retour à la liste des articles"/>
		</div>
	</div>
</div>

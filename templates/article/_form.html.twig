<div class="w-full max-w-md">
	<div class="p-8 flex flex-col w-full h-full text-gray-700 bg-pink-50 shadow-xl rounded-3xl border border-pink-100 mt-10 ">
		<h2 class="text-2xl font-semibold text-center text-gray-800 mb-8">Ajouter un article  💕</h2>
		<div class="mb-8">
			<!-- Full Name -->
			<div class="flex flex-col ">
				{{ form_label(form.name, null, {
                label_attr: { class: 'block text-sm font-medium text-gray-600 mb-2' }
            }) }}

				{{ form_widget(form.name, {
                attr: {
                    class: '
                        w-full px-5 py-3 
                        rounded-2xl 
                        border border-gray-200 
                        text-gray-800
                        focus:outline-none 
                        focus:ring-2 focus:ring-blue-400 
                        focus:border-blue-400 
                        transition
                        bg-blue-50
                    '
                }
            }) }}

				{{ form_errors(form.name) }}
			</div>

			<!-- Submit Button -->
			<div class="flex mt-8">
				<button type="submit" class=" grow
                                        text-gray-700
                                        font-medium
                                        shadow-md
                                        active:scale-95
                                        transition-all duration-200
                                        bg-gradient-to-r from-blue-400 to-indigo-400 rounded-full
                                        ">
					Valider
				</button>
			</div>
		</div>
	</div>
</div>

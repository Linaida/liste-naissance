<table class="w-full text-left table-auto min-w-max">
	<thead>
		<tr class="border-b border-pink-200 bg-gradient-to-r from-pink-100 to-blue-200 text-pink-700">
			<th class="p-4 text-sm font-medium">
				<p class="text-sm leading-none font-normal">
					ID
				</p>
			</th>
			<th class="p-4 text-sm font-medium">
				<p class="text-sm leading-none font-normal">
					Nom
				</p>
			</th>
			<th class="p-4 text-sm font-medium">
				<p class="text-sm leading-none font-normal">
					Ajouté le
				</p>
			</th>
			<th class="p-4 text-sm font-medium">
				<p class="text-sm leading-none font-normal">
					Réservé
				</p>
			</th>
			<th class="p-4 text-sm font-medium">
				<p class="text-sm leading-none font-normal">
					Prix
				</p>
			</th>

			<th class="p-4 text-sm font-medium">
				<p class="text-sm leading-none font-normal">
					Catégorie
				</p>
			</th>
			<th class="p-4 text-sm font-medium">
				<p class="text-sm leading-none font-normal">
					Actions
				</p>
			</th>
		</tr>
	</thead>
	<tbody>
		{% for article in articles %}
			<tr id="article_{{ article.id }}" class="hover:bg-blue-50 transition-colors duration-200">
				<td class="p-4 text-sm font-semibold text-pink-600">
					{{ article.id }}
				</td>
				<td class="p-4 text-sm text-gray-700">
					{{ article.name }}
				</td>
				<td class="p-4 text-sm text-gray-500">
					{{ article.createdAt ? article.createdAt|date('d/m/Y') : 'N/A' }}

				</td>
				<td class="p-4">
					{% if article.booked %}
						<span class="px-3 py-1 text-xs font-semibold text-pink-700 bg-pink-200 rounded-full shadow-sm">
							Réservé
						</span>
					{% else %}
						<span class="px-3 py-1 text-xs font-semibold text-emerald-700 bg-emerald-100 rounded-full shadow-sm">
							Disponible
						</span>
					{% endif %}
				</td>
				<td class="p-4 text-sm text-gray-400">
					{{ article.price ? article.price ~ ' €' : 'N/A' }}
				</td>
				<td class="p-2 text-sm text-gray-400">
					{{ article.category.label() | default('N/A') }}
				</td>
				<td class="p-4">
					<a href="{{ path('articles_edit', {id: article.id}) }}" data-turbo="false" class="px-4 py-1 text-xs font-semibold text-white
														          bg-gradient-to-r from-blue-400 to-indigo-400
														          rounded-full shadow-md hover:scale-105 transition">
						Éditer
					</a>
					<button class="px-4 py-1 text-xs font-semibold text-white bg-gradient-to-r from-red-400 to-red-600 rounded-full shadow-md hover:scale-105 transition-transform duration-150">
						Supprimer
					</button>
				</td>
			</tr>
		{% endfor %}
	</tbody>
</table>

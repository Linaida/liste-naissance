<div data-controller="reservations-modal">
	<table class="w-full text-left table-auto min-w-max">
		<thead>
			<tr class="border-b border-pink-200 bg-linear-to-r from-pink-100 to-blue-200 text-pink-700">
				<th class="p-4 text-sm font-medium">
					<p class="text-sm leading-none font-normal">
						ID
					</p>
				</th>
				<th class="p-4 text-sm font-medium">
					<p class="text-sm leading-none font-normal">
						Nom
					</p>
				</th>
				<th class="p-4 text-sm font-medium">
					<p class="text-sm leading-none font-normal">
						Ajouté le
					</p>
				</th>
				<th class="p-4 text-sm font-medium">
					<p class="text-sm leading-none font-normal">
						Réservé
					</p>
				</th>
				<th class="p-4 text-sm font-medium">
					<p class="text-sm leading-none font-normal">
						Prix
					</p>
				</th>

				<th class="p-4 text-sm font-medium">
					<p class="text-sm leading-none font-normal">
						Catégorie
					</p>
				</th>
				<th class="p-4 text-sm font-medium">
					<p class="text-sm leading-none font-normal">
						Actions
					</p>
				</th>
			</tr>
		</thead>
		<tbody>
			{% for article in articles %}
				<tr id="article_{{ article.id }}" class="hover:bg-blue-50 transition-colors duration-200">
					<td class="p-4 text-sm font-semibold text-pink-600">
						{{ article.id }}
					</td>
					<td class="p-4 text-sm text-gray-700">
						{{ article.name }}
					</td>
					<td class="p-4 text-sm text-gray-500">
						{{ article.createdAt ? article.createdAt|date('d/m/Y') : 'N/A' }}

					</td>
					<td class="p-4">
						{% if article.booked %}
							<span class="px-3 py-1 text-xs font-semibold text-pink-700 bg-pink-200 rounded-full shadow-sm">
								Réservé
							</span>
						{% else %}
							<span class="px-3 py-1 text-xs font-semibold text-emerald-700 bg-emerald-100 rounded-full shadow-sm">
								Disponible
							</span>
						{% endif %}
					</td>
					<td class="p-4 text-sm text-gray-400">
						{{ article.price ? article.price ~ ' €' : 'N/A' }}
					</td>
					<td class="p-2 text-sm text-gray-400">
						{{ article.category.label() | default('N/A') }}
					</td>
					<td class="p-4 space-x-2 flex items-center">
						{% if article.booked %}
							<button 
								type="button"
								data-action="reservations-modal#openReservations"
								data-article-id="{{ article.id }}"
								data-article-name="{{ article.name }}"
								class="px-3 py-1 text-xs font-semibold text-white
										bg-linear-to-r from-green-400 to-green-500
										rounded-full shadow-md hover:scale-105 transition whitespace-nowrap">
								📋 Réservations
							</button>
						{% endif %}
						<a href="{{ path('articles_edit', {id: article.id}) }}" data-turbo="false" class="px-3 py-1 text-xs font-semibold text-white
								bg-linear-to-r from-blue-400 to-indigo-400
								rounded-full shadow-md hover:scale-105 transition whitespace-nowrap">
							✏️ Éditer
						</a>
						<button type="button"
							data-turbo="false" 
							data-controller="dialog"
					        data-action="click->dialog#open"		
							data-dialog-id="confirmDialog"
							data-dialog-csrf="{{ csrf_token('delete' ~ article.id) }}"			
					        data-dialog-name="{{ article.name }}"
							data-dialog-title="Supprimer un article"
                			data-dialog-message="Voulez-vous vraiment supprimer cet article ?"
                			data-dialog-url="{{ path('articles_delete', {id: article.id}) }}"
					        class="px-3 py-1 text-xs font-semibold text-white
					               bg-linear-to-r from-red-400 to-red-600
					               rounded-full shadow-md hover:scale-105 transition whitespace-nowrap">
						🗑️ Supprimer
					</button>
					</td>
				</tr>
			{% endfor %}
		</tbody>
	</table>

	{# Dialog UNIQUE pour la confirmation de suppression #}
	<twig:ConfirmDialog id="confirmDialog"/>

	{# Modal UNIQUE pour les réservations #}
	<div data-reservations-modal-target="modal" data-action="click->reservations-modal#closeOnBackdrop" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4">
		<div class="bg-white rounded-2xl shadow-2xl max-w-2xl w-full max-h-[80vh] flex flex-col">
			{# Header #}
			<div class="flex items-center justify-between p-6 border-b border-gray-200">
				<h3 data-reservations-modal-target="title" class="text-lg font-semibold text-gray-900"></h3>
				<button
					type="button"
					data-action="reservations-modal#closeReservations"
					class="text-gray-500 hover:text-gray-700 text-2xl"
				>
					✕
				</button>
			</div>

			{# Content #}
			<div class="p-6 overflow-y-auto flex-1" data-reservations-modal-target="content">
				<!-- Contenu chargé dynamiquement -->
			</div>

			{# Footer #}
			<div class="flex justify-end p-6 border-t border-gray-200">
				<button
					type="button"
					data-action="reservations-modal#closeReservations"
					class="px-6 py-2 bg-gray-300 text-gray-800 rounded-lg hover:bg-gray-400 transition font-medium"
				>
					Fermer
				</button>
			</div>
		</div>
	</div>
</div>


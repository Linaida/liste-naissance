{% extends 'base.html.twig' %}

{% block title %}Accueil{% endblock %}

{% block body %}

	<div
		class="flex flex-col ">
		<twig:Card class="p-1 mt-2 bg-pink-50 shadow-xl rounded-3xl border border-pink-100 mx-auto w-sm md:w-3/4 lg:w-1/2">
					<twig:Card:Header>
						<twig:Card:Title class="text-center text-2xl text-indigo-800">Bienvenue sur notre liste de naissance !</twig:Card:Title>
						<twig:Card:Description></twig:Card:Description>
					</twig:Card:Header>
					<twig:Card:Content class="sm:mt-10">
						<div class="flex flex-col align-center content-center justify-center w-full border-2 border-pink-100 rounded-lg p-4 text-center text-indigo-900">
							<p class="text-lg italic">Où en sommes-nous
							</p>
							<p>
								Semaine : <span class="font-bold">{{ semaineActuelle|round }}</span>
							</P>
							<p>
								Terme prévu pour le <span class="font-bold">{{ termePrevu|date('d/m/Y') }}</span>
							</p>
						</div>
					</twig:Card:Content>
					<twig:Card:Footer class="">
						<div class="flex align-center content-center justify-center w-full">
							<twig:Button variant="default" class="ml-4">
								<twig:ux:icon name="ph:gender-female"/>Connaître le sexe du bébé
								<twig:ux:icon name="ph:gender-male"/>
							</twig:Button>
						</div>
					</twig:Card:Footer>
				</twig:Card>
	</div>

{% endblock %}

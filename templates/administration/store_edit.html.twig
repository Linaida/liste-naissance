{% extends 'base.html.twig' %}

{% block title %}Éditer une plateforme{% endblock %}

{% block body %}
<div class="container mx-auto p-6">
	<twig:Header />

	<div class="max-w-2xl mx-auto mt-8">
		<h1 class="text-3xl font-bold text-center mb-8 text-purple-800">
			✏️ Éditer une plateforme
		</h1>

		<div class="
			p-6
			bg-purple-50/95
			backdrop-blur-md
			rounded-2xl
			border border-white/40
			shadow-lg
		">
			<form method="post" class="space-y-6">
				<div class="flex flex-col">
					{{ form_label(form.name, null, {
						label_attr: { class: 'text-sm font-medium text-purple-700 mb-2' }
					}) }}
					{{ form_widget(form.name, {
						attr: {
							class: 'px-4 py-2 rounded-lg border border-white/50 bg-white/70 backdrop-blur-sm text-purple-800 focus:outline-none focus:ring-2 focus:ring-purple-300'
						}
					}) }}
					{{ form_errors(form.name) }}
				</div>

				<div class="flex flex-col">
					{{ form_label(form.searchUrlPattern, null, {
						label_attr: { class: 'text-sm font-medium text-purple-700 mb-2' }
					}) }}
					{{ form_widget(form.searchUrlPattern, {
						attr: {
							class: 'px-4 py-2 rounded-lg border border-white/50 bg-white/70 backdrop-blur-sm text-purple-800 focus:outline-none focus:ring-2 focus:ring-purple-300',
							placeholder: 'https://www.amazon.fr/s?k={query}'
						}
					}) }}
					{{ form_errors(form.searchUrlPattern) }}
					<p class="text-xs text-purple-600 mt-2">
						Utilisez <code>{query}</code> pour représenter le terme de recherche
					</p>
				</div>

				<div class="flex flex-col">
					{{ form_label(form.regex, null, {
						label_attr: { class: 'text-sm font-medium text-purple-700 mb-2' }
					}) }}
					{{ form_widget(form.regex, {
						attr: {
							class: 'px-4 py-2 rounded-lg border border-white/50 bg-white/70 backdrop-blur-sm text-purple-800 focus:outline-none focus:ring-2 focus:ring-purple-300',
							placeholder: '/amazon\\.fr/i'
						}
					}) }}
					{{ form_errors(form.regex) }}
					<p class="text-xs text-purple-600 mt-2">
						Expression régulière pour détecter automatiquement cette plateforme
					</p>
				</div>

				<div class="flex items-center">
					{{ form_widget(form.active, {
						attr: {
							class: 'rounded'
						}
					}) }}
					{{ form_label(form.active, null, {
						label_attr: { class: 'text-sm font-medium text-purple-700 ml-2' }
					}) }}
				</div>

				<div class="flex justify-center gap-4">
					<button type="submit" class="
						px-8 py-3
						text-white font-semibold
						rounded-lg
						bg-gradient-to-r from-purple-400 to-purple-500
						hover:shadow-lg
						hover:scale-105
						active:scale-95
						transition-all duration-200
					">
						✅ Enregistrer
					</button>
					<a href="{{ path('app_administration') }}" class="
						px-8 py-3
						text-purple-700 font-semibold
						rounded-lg
						bg-white border border-purple-300
						hover:shadow-lg
						hover:scale-105
						active:scale-95
						transition-all duration-200
					">
						❌ Annuler
					</a>
				</div>
				{{ form_rest(form) }}
			</form>
		</div>
	</div>
</div>
{% endblock %}

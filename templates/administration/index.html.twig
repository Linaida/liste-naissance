{% extends 'base.html.twig' %}

{% block title %}Administration{% endblock %}

{% block body %}
<div class="administration">

	<div class="container mx-auto p-6">
		<h1 class="text-4xl font-bold text-center mb-12 text-indigo-800">
			⚙️ Panneau d'Administration
		</h1>

		{# Flash messages #}
		{% if app.flashes %}
			{% for type, messages in app.flashes %}
				{% for message in messages %}
					<div class="mb-4 p-4 rounded-lg bg-green-100 text-green-800 border border-green-300">
						{{ message }}
					</div>
				{% endfor %}
			{% endfor %}
		{% endif %}

		<div class="grid grid-cols-1 gap-8">

			{# ===== SECTION 1: GROSSESSE ===== #}
			<section class="
				p-6
				bg-blue-50/95
				backdrop-blur-md
				rounded-2xl
				border border-white/40
				shadow-lg
			">
				<h2 class="text-2xl font-bold text-blue-800 mb-6">
					🤰 Informations sur la Grossesse
				</h2>

				<form method="post" class="space-y-6">
					<div class="grid grid-cols-1 md:grid-cols-3 gap-6">

						{# Date début #}
						<div class="flex flex-col">
							{{ form_label(pregnancy_form.startDate, null, {
								label_attr: { class: 'text-sm font-medium text-blue-700 mb-2' }
							}) }}
							{{ form_widget(pregnancy_form.startDate, {
								attr: {
									class: 'px-4 py-2 rounded-lg border border-white/50 bg-white/70 backdrop-blur-sm text-blue-800 focus:outline-none focus:ring-2 focus:ring-blue-300'
								}
							}) }}
							{{ form_errors(pregnancy_form.startDate) }}
						</div>

						{# Date fin #}
						<div class="flex flex-col">
							{{ form_label(pregnancy_form.endDate, null, {
								label_attr: { class: 'text-sm font-medium text-blue-700 mb-2' }
							}) }}
							{{ form_widget(pregnancy_form.endDate, {
								attr: {
									class: 'px-4 py-2 rounded-lg border border-white/50 bg-white/70 backdrop-blur-sm text-blue-800 focus:outline-none focus:ring-2 focus:ring-blue-300'
								}
							}) }}
							{{ form_errors(pregnancy_form.endDate) }}
						</div>

						{# Sexe du bébé #}
						<div class="flex flex-col">
							{{ form_label(pregnancy_form.babyGender, null, {
								label_attr: { class: 'text-sm font-medium text-blue-700 mb-2' }
							}) }}
							{{ form_widget(pregnancy_form.babyGender, {
								attr: {
									class: 'px-4 py-2 rounded-lg border border-white/50 bg-white/70 backdrop-blur-sm text-blue-800 focus:outline-none focus:ring-2 focus:ring-blue-300'
								}
							}) }}
							{{ form_errors(pregnancy_form.babyGender) }}
						</div>
					</div>

					<div class="flex justify-center">
						<button type="submit" class="
							px-8 py-3
							text-white font-semibold
							rounded-lg
							bg-gradient-to-r from-blue-400 to-blue-500
							hover:shadow-lg
							hover:scale-105
							active:scale-95
							transition-all duration-200
						">
							✅ Enregistrer les informations
						</button>
					</div>
					{{ form_rest(pregnancy_form) }}
				</form>
			</section>

			{# ===== SECTION 2: PLATEFORMES ===== #}
			<section class="
				p-6
				bg-purple-50/95
				backdrop-blur-md
				rounded-2xl
				border border-white/40
				shadow-lg
			">
				<h2 class="text-2xl font-bold text-purple-800 mb-6">
					🛍️ Gestion des Plateformes de Vente
				</h2>

				{# Formulaire d'ajout #}
				<div class="mb-8 p-4 bg-white/50 rounded-lg">
					<h3 class="text-lg font-semibold text-purple-700 mb-4">Ajouter une plateforme</h3>
					<form method="post" class="space-y-4">
						<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
							<div class="flex flex-col">
								{{ form_label(store_form.name, null, {
									label_attr: { class: 'text-sm font-medium text-purple-700 mb-2' }
								}) }}
								{{ form_widget(store_form.name, {
									attr: {
										class: 'px-4 py-2 rounded-lg border border-white/50 bg-white/70 backdrop-blur-sm text-purple-800 focus:outline-none focus:ring-2 focus:ring-purple-300',
										placeholder: 'ex: Amazon'
									}
								}) }}
								{{ form_errors(store_form.name) }}
							</div>

							<div class="flex flex-col">
								{{ form_label(store_form.searchUrlPattern, null, {
									label_attr: { class: 'text-sm font-medium text-purple-700 mb-2' }
								}) }}
								{{ form_widget(store_form.searchUrlPattern, {
									attr: {
										class: 'px-4 py-2 rounded-lg border border-white/50 bg-white/70 backdrop-blur-sm text-purple-800 focus:outline-none focus:ring-2 focus:ring-purple-300',
										placeholder: 'https://www.amazon.fr/s?k={query}'
									}
								}) }}
								{{ form_errors(store_form.searchUrlPattern) }}
							</div>

							<div class="flex flex-col">
								{{ form_label(store_form.regex, null, {
									label_attr: { class: 'text-sm font-medium text-purple-700 mb-2' }
								}) }}
								{{ form_widget(store_form.regex, {
									attr: {
										class: 'px-4 py-2 rounded-lg border border-white/50 bg-white/70 backdrop-blur-sm text-purple-800 focus:outline-none focus:ring-2 focus:ring-purple-300',
										placeholder: '/amazon\\.fr/i'
									}
								}) }}
								{{ form_errors(store_form.regex) }}
							</div>

							<div class="flex items-end">
								{{ form_widget(store_form.active, {
									attr: {
										class: 'rounded'
									}
								}) }}
								{{ form_label(store_form.active, null, {
									label_attr: { class: 'text-sm font-medium text-purple-700 ml-2' }
								}) }}
							</div>
						</div>

						<div class="flex justify-center">
							<button type="submit" class="
								px-6 py-2
								text-white font-semibold
								rounded-lg
								bg-gradient-to-r from-purple-400 to-purple-500
								hover:shadow-lg
								hover:scale-105
								active:scale-95
								transition-all duration-200
							">
								➕ Ajouter
							</button>
						</div>
						{{ form_rest(store_form) }}
					</form>
				</div>

				{# Liste des plateformes #}
				<div>
					<h3 class="text-lg font-semibold text-purple-700 mb-4">Plateformes existantes</h3>
					{% if stores is not empty %}
						<div class="space-y-3">
							{% for store in stores %}
								<div class="
									p-4 bg-white/50 rounded-lg
									border border-purple-200
									flex items-center justify-between
									hover:bg-white/70 transition
								">
									<div class="flex-1">
										<h4 class="font-semibold text-purple-800">{{ store.name }}</h4>
										<p class="text-sm text-purple-600">{{ store.searchUrlPattern }}</p>
										{% if store.regex %}
											<p class="text-xs text-purple-500 mt-1">
												<code>{{ store.regex }}</code>
											</p>
										{% endif %}
										<span class="inline-block mt-2 text-xs px-2 py-1 rounded {% if store.isActive() %}bg-green-100 text-green-700{% else %}bg-red-100 text-red-700{% endif %}">
											{% if store.isActive() %}✅ Actif{% else %}❌ Inactif{% endif %}
										</span>
									</div>
									<div class="flex gap-2 ml-4">
										<a href="{{ path('app_administration_store_edit', {id: store.id}) }}" class="
											px-4 py-2
											text-sm font-medium text-white
											rounded-lg
											bg-blue-500
											hover:bg-blue-600
											transition
										">
											✏️ Éditer
										</a>
										<a href="{{ path('app_administration_store_delete', {id: store.id}) }}" class="
											px-4 py-2
											text-sm font-medium text-white
											rounded-lg
											bg-red-500
											hover:bg-red-600
											transition
											onclick="return confirm('Êtes-vous sûr?');"
										">
											🗑️ Supprimer
										</a>
									</div>
								</div>
							{% endfor %}
						</div>
					{% else %}
						<p class="text-center text-purple-600 py-8">Aucune plateforme ajoutée pour le moment.</p>
					{% endif %}
				</div>
			</section>

			{# ===== SECTION 3: UTILISATEURS ===== #}
			{% if user_form and admin_user %}
				<section class="
					p-6
					bg-green-50/95
					backdrop-blur-md
					rounded-2xl
					border border-white/40
					shadow-lg
				">
					<h2 class="text-2xl font-bold text-green-800 mb-6">
						👤 Gestion des Utilisateurs
					</h2>

					<form method="post" class="space-y-6">
						<div class="grid grid-cols-1 md:grid-cols-2 gap-6">

							{# Email #}
							<div class="flex flex-col">
								{{ form_label(user_form.email, null, {
									label_attr: { class: 'text-sm font-medium text-green-700 mb-2' }
								}) }}
								{{ form_widget(user_form.email, {
									attr: {
										class: 'px-4 py-2 rounded-lg border border-white/50 bg-white/70 backdrop-blur-sm text-green-800 focus:outline-none focus:ring-2 focus:ring-green-300'
									}
								}) }}
								{{ form_errors(user_form.email) }}
								<p class="text-xs text-green-600 mt-2">
									Email actuel: <strong>{{ admin_user.email }}</strong>
								</p>
							</div>

							{# Mot de passe #}
							<div class="flex flex-col">
								{{ form_label(user_form.password, null, {
									label_attr: { class: 'text-sm font-medium text-green-700 mb-2' }
								}) }}
								{{ form_widget(user_form.password, {
									attr: {
										class: 'px-4 py-2 rounded-lg border border-white/50 bg-white/70 backdrop-blur-sm text-green-800 focus:outline-none focus:ring-2 focus:ring-green-300',
										placeholder: 'Laisser vide pour ne pas modifier'
									}
								}) }}
								{{ form_errors(user_form.password) }}
							</div>
						</div>

						<div class="flex justify-center">
							<button type="submit" class="
								px-8 py-3
								text-white font-semibold
								rounded-lg
								bg-gradient-to-r from-green-400 to-green-500
								hover:shadow-lg
								hover:scale-105
								active:scale-95
								transition-all duration-200
							">
								✅ Mettre à jour
							</button>
						</div>
						{{ form_rest(user_form) }}
					</form>
				</section>
			{% endif %}
		</div>
	</div>
</div>
{% endblock %}

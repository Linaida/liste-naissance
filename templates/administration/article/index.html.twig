{% extends 'base.html.twig' %}

{% block title %}Administration | Articles
{% endblock %}

{% block body %}

	<div class="container mx-auto px-4 py-8">
		<div class="flex flex-col">
			<div class="relative p-8 flex flex-col w-full h-full text-gray-700 bg-pink-50 shadow-xl rounded-3xl border border-pink-100 ">
				<div class="flex flex-col items-center gap-8 mb-8">
					<div
						class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6 mb-8">

						<!-- Bloc gauche : titre + description -->
						<div class="flex flex-col gap-1 text-left">
							<h5 class="text-2xl font-semibold text-gray-800">
								Mes articles de naissance
							</h5>
							<p class="text-sm text-gray-600">
								Liste de tous les articles disponibles dans le système.
							</p>
						</div>

						<!-- Bloc droite : actions -->
						<div class="flex gap-3">
							<button class="px-4 py-2 text-xs font-semibold rounded-full bg-blue-100 text-blue-700 hover:bg-blue-200 transition">
								Filtrer
							</button>

							<button class="px-5 py-2 text-xs font-semibold text-white rounded-full bg-gradient-to-r from-blue-400 to-indigo-400 shadow-md hover:scale-105 transition-transform duration-150">
								Ajouter un article
							</button>
						</div>

					</div>
					<table class="w-full text-left table-auto min-w-max">
						<thead>
							<tr class="border-b border-pink-200 bg-gradient-to-r from-pink-100 to-blue-200 text-pink-700">
								<th class="p-4 text-sm font-medium">
									<p class="text-sm leading-none font-normal">
										ID
									</p>
								</th>
								<th class="p-4 text-sm font-medium">
									<p class="text-sm leading-none font-normal">
										Nom
									</p>
								</th>
								<th class="p-4 text-sm font-medium">
									<p class="text-sm leading-none font-normal">
										Ajouté le
									</p>
								</th>
								<th class="p-4 text-sm font-medium">
									<p class="text-sm leading-none font-normal">
										Réservé
									</p>
								</th>
								<th class="p-4 text-sm font-medium">
									<p class="text-sm leading-none font-normal">
										Prix
									</p>
								</th>
								<th class="p-4 text-sm font-medium">
									<p class="text-sm leading-none font-normal">
										Actions
									</p>
								</th>
							</tr>
						</thead>
						<tbody>
							{% for article in articles %}
								<tr id="article_{{ article.id }}" class="hover:bg-blue-50 transition-colors duration-200">
									<td class="p-4 text-sm font-semibold text-pink-600">
										{{ article.id }}
									</td>
									<td class="p-4 text-sm text-gray-700">
										{{ article.name }}
									</td>
									<td class="p-4 text-sm text-gray-500">
										{{ article.createdAt ? article.createdAt|date('d/m/Y') : 'N/A' }}

									</td>
									<td class="p-4">
										{% if article.booked %}
											<span class="px-3 py-1 text-xs font-semibold text-pink-700 bg-pink-200 rounded-full shadow-sm">
												Réservé
											</span>
										{% else %}
											<span class="px-3 py-1 text-xs font-semibold text-emerald-700 bg-emerald-100 rounded-full shadow-sm">
												Disponible
											</span>
										{% endif %}
									</td>
									<td class="p-4 text-sm text-gray-400">
										N/A
									</td>
									<td class="p-4">
										<button class="px-4 py-1 text-xs font-semibold text-white bg-gradient-to-r from-blue-400 to-indigo-400 rounded-full shadow-md hover:scale-105 transition-transform duration-150">
											Éditer
										</button>
										<button class="px-4 py-1 text-xs font-semibold text-white bg-gradient-to-r from-red-400 to-red-600 rounded-full shadow-md hover:scale-105 transition-transform duration-150">
											Supprimer
										</button>
									</td>
								</tr>
							{% endfor %}
						</tbody>
					</table>
				</div>
			</div>
		</div>
	{% endblock %}
